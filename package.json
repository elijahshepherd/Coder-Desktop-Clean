{
  "name": "coder-desktop",
  "version": "0.1.1",
  "description": "Local-first AI coding workspace for focused desktop software development.",
  "main": "dist/main/main.js",
  "author": "Elijah Shepherd",
  "license": "SEE LICENSE IN LICENSE.md",
  "repository": {
    "type": "git",
    "url": "https://github.com/elijahshepherd/Coder-Desktop.git"
  },
  "bugs": {
    "url": "https://github.com/elijahshepherd/Coder-Desktop/issues"
  },
  "homepage": "https://github.com/elijahshepherd/Coder-Desktop#readme",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "sync:version": "node scripts/write-shared-version.mjs",
    "predev": "npm run sync:version",
    "pretypecheck": "npm run sync:version",
    "pretest": "npm run sync:version",
    "predist": "npm run sync:version",
    "prepackage": "npm run sync:version",
    "prerelease:current": "npm run sync:version",
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc -p tsconfig.electron.json --noEmit",
    "clean": "node scripts/clean-dist.mjs",
    "build": "npm run clean && npm run typecheck && vite build && tsc -p tsconfig.electron.json",
    "test": "vitest run",
    "package": "npm run build",
    "dist": "npm run build && electron-builder",
    "release:windows": "powershell -ExecutionPolicy Bypass -File scripts/build-windows.ps1",
    "release:windows:nsis": "powershell -ExecutionPolicy Bypass -File scripts/build-windows.ps1 -Target nsis",
    "release:macos": "npm run build && electron-builder --mac zip --x64 --arm64",
    "release:manifest": "node scripts/write-download-manifest.mjs",
    "release:current": "powershell -ExecutionPolicy Bypass -File scripts/release-version.ps1"
  },
  "dependencies": {
    "diff": "^9.0.0",
    "lucide-react": "^0.468.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/diff": "^7.0.2",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1",
    "playwright": "^1.60.0",
    "png-to-icns": "^1.0.0",
    "sharp": "^0.35.3",
    "typescript": "^5.7.2",
    "vite": "^8.0.16",
    "vitest": "^4.1.8",
    "wait-on": "^8.0.1"
  }
}
